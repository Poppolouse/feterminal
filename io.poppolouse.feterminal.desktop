[Desktop Entry]
Name=feterminal
Comment=Lightweight GTK terminal with editable shortcuts
Exec=/var/home/poppolouse/.local/bin/feterminal %f
Icon=io.poppolouse.feterminal
Terminal=false
Type=Application
Categories=System;TerminalEmulator;GTK;
StartupWMClass=io.poppolouse.feterminal
MimeType=application/x-feterminal-project;
